[node name="Tutorial_guy" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.972027, 0, -0.234871, 0, 1, 0, 0.234871, 0, 0.972027, -14.3833, 1.36514, -3.34713)
dialog = "Hey kid, you look like you're new on the streets. Go to the next room, and i'll tell ya a little bit about how to do combat."

[node name="Tutorial_guy2" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.732139, 0, 0.681156, 0, 1, 0, -0.681156, 0, 0.732139, -21.0702, 1.36514, -18.742)
dialog = "So, you wanna learn street-jitsu huh? Well if ya wanna start why don'tcha pick up some of these rocks, and throw them at that bloke over there?"

[node name="Tutorial_guy3" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.98555, 0, 0.169384, 0, 1, 0, -0.169384, 0, 0.98555, -21.0719, 1.38391, -53.085)
dialog = "Alright... Not bad kid. As you can see, this guy dropped some cash. Walk near it to pick it up. Head left, and i'll tell ya about parrying."

[node name="Tutorial_guy4" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.230678, 0, 0.97303, 0, 1, 0, -0.97303, 0, 0.230678, -43.1615, 1.39072, -46.6467)
dialog = "Alright, so. If you got an empty hand, or press [F], you can punch. Now if there is a rock flying towards yer face, you could pucnh it to deflect it in the direction you are looking in. Try it out in the next room."

[node name="Tutorial_guy5" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.999382, 0, -0.0351612, 0, 1, 0, 0.0351612, 0, 0.999382, -73.7076, 1.39072, -58.8642)
dialog = "Good job, kid. Now, lemme tell you something. 3 items, is not the max you can hold. By pressing [TAB] you can open your inventory. Get farmiliar with it."

[node name="Tutorial_guy6" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.999382, 0, -0.0351612, 0, 1, 0, 0.0351612, 0, 0.999382, -77.364, 1.39469, -77.1055)
dialog = "You may notice that brown bar in your inventory, that is your hunger. If it isn't full by the end of the day, you won't heal up after sleeping so it's important to eat."

[node name="Tutorial_guy7" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.999382, 0, -0.0351612, 0, 1, 0, 0.0351612, 0, 0.999382, -77.3626, 1.41458, -106.716)
dialog = "Behind me is a gas station. You can spend your hard earned cash here, for some food or weapons."

[node name="Tutorial_guy8" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.259746, 0, 0.965677, 0, 1, 0, -0.965677, 0, 0.259746, -85.4372, 1.64031, -151.748)
dialog = "Alright. After you've finished shopping, head back, and go straight at the room with 2 enterances. Press [CTRL] to slide there faster."

[node name="Tutorial_guy9" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.148569, 0, -0.988902, 0, 1, 0, 0.988902, 0, 0.148569, 4.5924, 1.38355, -48.8733)
dialog = "Behind me is a boss room. There usually is a really big and tough guy in there, but it looks like some chumps took him down already."

[node name="Tutorial_guy10" parent="." instance=ExtResource("11_ud3r4")]
transform = Transform3D(0.148569, 0, -0.988902, 0, 1, 0, 0.988902, 0, 0.148569, 59.0251, 1.38355, -48.1114)
dialog = "Listen, i know you live in a cardoard box. But how about i offer you a deal. If you earn $150, i can get you a \"livable\" apartment. What do you say to that?"

